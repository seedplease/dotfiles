alias syncup="doas pacman -Syy"
alias upgrade="doas pacman -Syu"
alias myip="curl ipinfo.io"
alias autoremove="doas pacman -Qdtq | doas pacman -Rs -"
alias cls="clear"
alias ex="exit"
alias cp="cp -iv"
alias mv="mv -iv"
alias rm="rm -v"
alias la="ls -a"
alias mkd="mkdir -pv"
alias cpumon="watch -n1 'cat /proc/cpuinfo | grep \"^[c]pu MHz\" ; sensors'"
alias rmatrix="cmatrix -abk -C cyan"
