alias sudo="doas"
alias syncup="doas pacman -Syy"
alias upgrade="yay -Syu"
alias myip="curl ipinfo.io"
alias autoremove="pacman -Qdtq | doas pacman -Rs "
alias cls="clear"
alias ex="exit"
alias cp="cp -iv"
alias mv="mv -iv"
alias rm="rm -v"
alias la="ls -a"
alias lsl="ls -l"
alias lsla="ls -la"
alias clsl="clear && ls -l"
alias clsla="clear && ls -la"
alias mkdir="mkdir -v"
alias mkd="mkdir -pv"
alias cpumon="watch -n1 'cat /proc/cpuinfo | grep \"^[c]pu MHz\" ; sensors'"
alias win10vm="doas virsh start win10"
